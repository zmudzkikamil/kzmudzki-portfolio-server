# PostgreSQL connection string (Supabase: Project Settings → Database → URI)
DATABASE_URL=

# Resend API key for contact form emails (resend.com)
RESEND_API_KEY=

# Email address that receives contact form submissions
RECIPIENT_EMAIL=

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173

# Server port (optional, defaults to 3000)
PORT=3000
